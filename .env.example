# Neon Postgres 연결 문자열 (https://console.neon.tech 에서 발급)
# 예: postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# 주의: prisma migrate 실행 시에는 -pooler가 붙지 않은 direct 연결 문자열을 사용하세요.
DATABASE_URL=

# 구글폼 설문 URL (미설정 시 lib/config.ts의 플레이스홀더 사용)
NEXT_PUBLIC_GOOGLE_FORM_URL=
